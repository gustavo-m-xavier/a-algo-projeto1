{
	"compilerOptions": {
		"declaration": true,
		"target": "es2020",
		"module": "nodenext",
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"strict": true,
		"sourceMap": false,
		"resolveJsonModule": true
	},
	"exclude": [
		"node_modules"
	],
	"include": [
		"src/**/*.ts"
	]
}